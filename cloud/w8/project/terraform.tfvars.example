# =============================================================================
# terraform.tfvars.example — Copy this to terraform.tfvars and fill in values
#
# IMPORTANT: terraform.tfvars contains sensitive data — DO NOT commit to git!
# =============================================================================

# AWS Region
aws_region = "ap-southeast-1"

# Project name (used as prefix for all resource names)
project_name = "k8s-demo"

# EC2 instance type — minimum t3.medium (2 vCPU / 4 GB RAM) for kind
instance_type = "t3.medium"

# EC2 Key Pair name (must already exist in your AWS account)
# Create via: aws ec2 create-key-pair --key-name my-keypair --query 'KeyMaterial' --output text > my-keypair.pem
key_name = "my-ec2-keypair"

# Absolute path to your PEM private key file
# Windows example: "C:/Users/username/.ssh/my-keypair.pem"
# macOS/Linux:     "/home/username/.ssh/my-keypair.pem"
private_key_path = "~/.ssh/my-ec2-keypair.pem"

# Your IP address in CIDR notation (DO NOT use 0.0.0.0/0 in production)
# Get your current IP: curl -s ifconfig.me && echo "/32"
allowed_ssh_cidr = "YOUR_IP_ADDRESS/32"

# Kubernetes NodePort (30000-32767)
node_port = 30080

# Kind cluster name
cluster_name = "demo-cluster"
